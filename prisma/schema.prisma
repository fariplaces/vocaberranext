datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id        String   @id
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  sessions  Session[]
  createdAt DateTime  @default(now())
}