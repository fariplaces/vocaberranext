// npx prisma generate
// npx prisma migrate dev --name init
// npx prisma studio

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// User table
model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  sessions     Session[]
  typings      Typing[]
  createdAt    DateTime      @default(now())
  revisions    Revision[]
  tasks        Task[]
  defaultTasks DefaultTask[]
  notes        Note[]
}

// Session table
model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Typing table (records per user)
model Typing {
  id         String   @id @default(uuid())
  userId     String
  exerciseId String
  durationId String
  accuracy   Float
  gross      Int
  net        Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])
  duration Duration @relation(fields: [durationId], references: [id])

  @@index([userId])
  @@index([exerciseId])
}

// Exercise table
model Exercise {
  id         String @id @default(uuid())
  title      String
  exerciseNo String @unique
  typeId     String
  lessonId   String

  type   ExerciseType @relation(fields: [typeId], references: [id])
  lesson Lesson       @relation(fields: [lessonId], references: [id])

  typings Typing[]
}

// ExerciseType table
model ExerciseType {
  id   String @id @default(uuid())
  type String @unique

  exercises Exercise[]
}

// Lesson table
model Lesson {
  id     String @id @default(uuid())
  lesson String @unique
  order  Int?

  exercises Exercise[]
}

// Duration table
model Duration {
  id       String @id @default(uuid())
  duration String @unique

  typings Typing[]
}

// Migration for R-III

model Skill {
  id         String     @id @default(uuid())
  title      String
  order      Int?
  categories Category[]
}

model Category {
  id       String  @id @default(uuid())
  title    String
  order    Int?
  parentId String?
  skillId  String? // Optional per your request

  // Relations
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  // Note: Made Skill optional here too to match skillId
  skill Skill? @relation(fields: [skillId], references: [id])

  topics Topic[]

  @@index([skillId])
  @@index([parentId])
}

model Topic {
  id         String @id @default(uuid())
  title      String
  categoryId String
  order      Int?

  category  Category   @relation(fields: [categoryId], references: [id])
  revisions Revision[]

  @@index([categoryId])
}

model Revision {
  id        String    @id @default(uuid())
  topicId   String
  userId    String
  scheduled DateTime
  practiced DateTime?

  revision1     Boolean   @default(false)
  revision1date DateTime?
  revision2     Boolean   @default(false)
  revision2date DateTime?
  revision3     Boolean   @default(false)
  revision3date DateTime?
  revision4     Boolean   @default(false)
  revision4date DateTime?
  revision5     Boolean   @default(false)
  revision5date DateTime?

  topic Topic @relation(fields: [topicId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([topicId])
  @@index([userId])
}

model Task {
  // Changed from Int to String with uuid()
  id String @id @default(uuid())

  // Relation to User (matching your String/UUID userId)
  user   User   @relation(fields: [userId], references: [id])
  userId String

  date    DateTime
  title   String
  remarks String?
  status  Boolean  @default(false)
  order   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DefaultTask {
  // Changed from Int to String with uuid()
  id String @id @default(uuid())

  // Relation to User
  user   User   @relation(fields: [userId], references: [id])
  userId String

  title   String
  remarks String?
  order   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MIGRATION FOR NOTION-LIKE NOTES ---

model Note {
  id    String  @id @default(uuid())
  title String? // Optional title for the note

  // Notion-style rich text content stored as a JSON string
  content String // You will JSON.stringify() your editor state here

  // Polymorphic connection fields
  targetId   String // The ID of the Topic, Exercise, etc.
  targetType String // Identifies the connected table (e.g., "TOPIC", "EXERCISE", "SKILL")

  // Every note should belong to a user
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([targetId]) // Crucial for querying notes for a specific topic fast
}

model NoteTemplate {
  id      String @id @default(uuid())
  name    String // Name of the template (e.g., "Bug Report", "Daily Reflection")
  pattern String @unique // The shortcut trigger (e.g., "bug", "daily")

  // The default Notion-style JSON content for this template
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
